# === CLion / JetBrains 相关 ===
.idea/                # 忽略 CLion 的项目配置文件（非常重要）
cmake-build-*/        # 忽略不同配置下的 CMake 编译输出目录
*.iws

# === Qt / CMake 产生的文件 ===
CMakeLists.txt.user   # 忽略用户本地的 CMake 配置
/build/               # 忽略通用的构建目录
.qt/                  # 忽略 Qt 的临时元数据
/bin/                 # 如果你设置了输出路径，忽略二进制输出

# 本机专用配置（例如 Qt 安装路径），不要提交到仓库
cmake/LocalConfig.cmake
/lib/                 # 忽略生成的库文件

# === 操作系统临时文件 ===
.DS_Store             # macOS
Thumbs.db             # Windows

cmake/